# Redrob AI Hiring Intelligence Platform - Environment Variables

# Embedding model
REDRob_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Score weights
REDRob_W_SEMANTIC=0.40
REDRob_W_STRUCTURAL=0.60

# Device (cpu or cuda)
REDRob_DEVICE=cpu

# Batch size
REDRob_EMBED_BATCH_SIZE=256

# Logging level
LOG_LEVEL=INFO
